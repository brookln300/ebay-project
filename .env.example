# ===========================================
# Sports Card eBay Lister - Environment Config
# ===========================================
# Copy this to .env.local and fill in your keys

# Anthropic (Claude API - card image scanning)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# eBay API (Developer Program: https://developer.ebay.com)
EBAY_APP_ID=your-app-id
EBAY_CERT_ID=your-cert-id
EBAY_DEV_ID=your-dev-id
EBAY_REDIRECT_URI=http://localhost:3000/api/ebay/callback
# Set to "SANDBOX" for testing, "PRODUCTION" for live
EBAY_ENVIRONMENT=SANDBOX

# Watch Directory (where you dump card images)
CARD_WATCH_DIR=C:\Users\knati\Documents\card-scans
